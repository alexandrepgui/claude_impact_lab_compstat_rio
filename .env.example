# CompStat Rio — Group 14 · ImpactHub
# Variáveis de ambiente da pipeline.
#
# Como usar:
#   1. Copie este arquivo:    cp .env.example .env
#   2. Edite .env com sua chave real
#   3. Pronto — _llm_client.py carrega automaticamente via python-dotenv
#
# O .env NUNCA é commitado (já está no .gitignore).
# O .env.example pode ser commitado como template.

# === Anthropic (Claude) ===
# Obter em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-COLE-SUA-CHAVE-AQUI

# Modelo default (mude se quiser, mas Sonnet é o econômico)
ANTHROPIC_MODEL=claude-sonnet-4-5

# === LLM tuning (opcional) ===
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.0

# === Pipeline (opcional) ===
# Threshold de confidence — abaixo disso vai pra fila humana
PIPELINE_CONFIDENCE_THRESHOLD=0.6
